# Corelia environment variables example
# NOTE: Sensitive vars are mandatory at runtime.
# Never rely on insecure fallbacks in production.

# PostgreSQL configuration
# Database name for the main Corelia schema.
POSTGRES_DB=corelia
# Database user used by api/workers.
POSTGRES_USER=corelia
# Strong password for PostgreSQL user.
POSTGRES_PASSWORD=change_this_postgres_password
# Full Prisma database URL.
DATABASE_URL=postgresql://corelia:change_this_postgres_password@localhost:5432/corelia?schema=public

# Redis configuration
# Redis connection URL.
REDIS_URL=redis://localhost:6379
# Redis password used by API and workers.
REDIS_PASSWORD=change_this_redis_password

# API runtime
# API bind host.
HOST=0.0.0.0
# API port.
PORT=4000
# Access token secret (minimum 16 chars).
JWT_ACCESS_SECRET=replace_with_secure_access_secret
# Refresh token secret (minimum 16 chars).
JWT_REFRESH_SECRET=replace_with_secure_refresh_secret
# Shared secret for collaboration JWT (API + Hocuspocus).
COLLAB_AUTH_SECRET=replace_with_secure_collab_secret
# CORS allowlist for production (comma-separated origins, no spaces).
CORS_ALLOWED_ORIGINS=http://localhost:3000
# Allow requests from private-network origins (RFC1918, *.local) for intranet deployments.
CORS_ALLOW_PRIVATE_NETWORK=false
# Access token lifetime in minutes (must be 15 in this phase).
ACCESS_TOKEN_TTL_MINUTES=15
# Refresh token lifetime in days.
REFRESH_TOKEN_TTL_DAYS=30
# Auto-apply Prisma migrations at API startup.
AUTO_MIGRATE_ON_START=true

# MinIO configuration
# MinIO endpoint host.
MINIO_ENDPOINT=localhost
# MinIO API port.
MINIO_PORT=9000
# Use TLS for MinIO endpoint.
MINIO_USE_SSL=false
# MinIO root/access key (non-default required).
MINIO_ROOT_USER=replace_with_minio_root_user
# MinIO root/secret key (non-default required).
MINIO_ROOT_PASSWORD=change_this_minio_password
# MinIO access key used by applications.
MINIO_ACCESS_KEY=replace_with_minio_root_user
# MinIO secret key used by applications.
MINIO_SECRET_KEY=change_this_minio_password
# Initial bucket name.
MINIO_BUCKET=corelia-files
# Presence heartbeat TTL for collaborative documents (seconds).
DOCUMENTS_PRESENCE_TTL_SECONDS=70
DOCUMENTS_DIAGRAM_SESSION_HEARTBEAT_MS=20000
DOCUMENTS_DIAGRAM_SESSION_SNAPSHOT_MS=30000
DOCUMENTS_DIAGRAM_SESSION_IDLE_SECONDS=900
# Background purge cadence for deleted collaborative documents (minutes).
DOCUMENTS_PURGE_INTERVAL_MINUTES=60

# SMTP integration
# SMTP host for transactional notifications.
SMTP_HOST=mail.local
# SMTP server port.
SMTP_PORT=587
# SMTP TLS mode.
SMTP_SECURE=false
# SMTP user.
SMTP_USER=corelia
# SMTP password.
SMTP_PASS=change_this_smtp_password
# Sender email address.
SMTP_FROM=noreply@corelia.local

# UI runtime
# Public API URL used by Next.js frontend.
# Use relative path so LAN clients can reuse current host.
NEXT_PUBLIC_API_URL=/api/v1
# Public WebSocket URL (Socket.io) used by frontend realtime client.
# Leave empty to auto-resolve from current host.
NEXT_PUBLIC_WS_URL=
# Public API URL baked into Docker web image (set to http://<LAN_IP>/api/v1 for local network clients).
NEXT_PUBLIC_API_URL_DOCKER=/api/v1
# Public WebSocket URL baked into Docker web image (set to http://<LAN_IP> or https://<HOST>).
NEXT_PUBLIC_WS_URL_DOCKER=
# Socket.io path exposed by API + Nginx.
NEXT_PUBLIC_SOCKET_PATH=/ws/socket.io
# Y.js/Hocuspocus endpoint for collaborative documents.
# In Docker behind nginx, keep /collab.
NEXT_PUBLIC_HOCUSPOCUS_URL=/collab
# Hocuspocus URL embedded during Docker web build.
NEXT_PUBLIC_HOCUSPOCUS_URL_DOCKER=/collab
# Enable verbose collaborative-doc debug logs in browser console.
NEXT_PUBLIC_DOCS_DEBUG=false
# Enable verbose WebRTC logs in browser console.
NEXT_PUBLIC_WEBRTC_DEBUG=false

# Maintenance mode defaults
# Message shown when maintenance mode is enabled.
MAINTENANCE_DEFAULT_MESSAGE="Corelia está en mantenimiento"

# Realtime and media server
# Enable/disable Socket.io server in API.
SOCKET_IO_ENABLED=true
# Socket.io path in API.
SOCKET_IO_PATH=/ws/socket.io
# Enable mediasoup-based media layer.
MEDIA_SERVER_ENABLED=true
# Maximum participants per meeting.
MEDIA_MAX_PARTICIPANTS=20
# Media listen IP.
MEDIA_LISTEN_IP=0.0.0.0
# Public announced media address for clients.
# In Docker on Linux, "host.docker.internal" can be resolved automatically via host-gateway.
MEDIA_ANNOUNCED_IP=host.docker.internal
# UDP/TCP media port range.
MEDIA_MIN_PORT=40000
MEDIA_MAX_PORT=40100

# Hocuspocus collaborative server
HOCUSPOCUS_HOST=0.0.0.0
HOCUSPOCUS_PORT=1234
HOCUSPOCUS_QUIET=false

# External calendar OAuth credentials
GOOGLE_CALENDAR_CLIENT_ID=replace_with_google_client_id
GOOGLE_CALENDAR_CLIENT_SECRET=replace_with_google_client_secret
GOOGLE_CALENDAR_REDIRECT_URI=http://localhost:3000/calendar/google/callback
MICROSOFT_CALENDAR_CLIENT_ID=replace_with_microsoft_client_id
MICROSOFT_CALENDAR_CLIENT_SECRET=replace_with_microsoft_client_secret
MICROSOFT_CALENDAR_REDIRECT_URI=http://localhost:3000/calendar/microsoft/callback

# Optional outgoing webhooks for meeting/task events
SLACK_WEBHOOK_URL=
TEAMS_WEBHOOK_URL=

# OpenTelemetry + Tempo
OTEL_ENABLED=true
OTEL_SERVICE_NAME_API=corelia-api
OTEL_SERVICE_NAME_WORKERS=corelia-workers
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# TLS certificates consumed by nginx container (must exist outside git-tracked files)
NGINX_SSL_CERT_PATH=./nginx/certs-local/corelia.crt
NGINX_SSL_KEY_PATH=./nginx/certs-local/corelia.key
