generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum SystemRole {
  ADMINISTRADOR
  LIDER_PROYECTO
  COORDINADOR_EQUIPO
  COLABORADOR
  OBSERVADOR
  INVITADO_EXTERNO
}

enum TaskStatus {
  PENDIENTE
  EN_REVISION
  COMPLETADA
}

enum ProjectTemplate {
  SOFTWARE
  CONTENIDO
  OPERACIONES
}

enum ProjectMembershipSource {
  MANUAL
  SYNC
}

enum AvailabilityType {
  VACACIONES
  PERMISO
  AUSENCIA
  NO_DISPONIBLE
}

enum NotificationChannel {
  EMAIL
  IN_APP
}

enum NotificationFrequency {
  INMEDIATA
  RESUMEN_DIARIO
}

enum NotificationEvent {
  TAREA_ASIGNADA
  TAREA_REASIGNADA
  TAREA_ESTADO_CAMBIADO
  MENSAJE_NUEVO_CANAL
  MENCION_MENSAJE
  REUNION_PROGRAMADA
  ACUERDO_ASIGNADO_TAREA
  TAREA_PROXIMA_VENCER
  TAREA_BLOQUEADA
  SOLICITUD_RESUELTA
}

enum RequestType {
  VACACIONES
  PERMISO
  ACCESO_RECURSO
}

enum RequestStatus {
  PENDIENTE
  APROBADA
  RECHAZADA
}

enum ChannelScope {
  EQUIPO
  PROYECTO
}

enum MessageKind {
  TEXT
  FILE
  CALL_INVITE
}

enum DocumentType {
  TEXTO
  DIAGRAMA
  TABLA
  WHITEBOARD
  PRESENTACION
}

enum DiagramEngine {
  EXCALIDRAW
  REACT_FLOW
}

enum DiagramKind {
  FLUJO
  SECUENCIA
  UML_CLASES
  ENTIDAD_RELACION
  ESTADO
  ARQUITECTURA
  BPMN
}

enum DocumentVersionKind {
  MANUAL
  AUTO
}

enum FolderScope {
  EQUIPO
  PROYECTO
}

enum EntityType {
  USUARIO
  PROYECTO
  TAREA
  REUNION
  ACUERDO_REUNION
  MENSAJE
  ARCHIVO
  SOLICITUD
  ANUNCIO
  OBJETIVO
  DECISION
  AUTOMATIZACION
}

enum ActionType {
  LOGIN
  LOGOUT
  CREAR
  ACTUALIZAR
  ELIMINAR
  PROGRAMAR_REUNION
  REGISTRAR_ACUERDO
  CAMBIO_ROL
  CAMBIO_ESTADO_TAREA
  REASIGNAR_TAREA
  APROBAR_SOLICITUD
  CAMBIO_PERMISO
}

enum MeetingStatus {
  PROGRAMADA
  EN_CURSO
  FINALIZADA
  CANCELADA
}

enum MeetingAgreementStatus {
  PENDIENTE_ACCION
  VINCULADO_TAREA
  COMPLETADO
}

enum ExternalCalendarProvider {
  GOOGLE
  MICROSOFT
}

enum AutomationEvent {
  TAREA_COMPLETADA
  TAREA_SIN_MOVIMIENTO
  TAREA_REASIGNADA
  TAREA_VENCIDA
  SOLICITUD_RESUELTA
}

enum AutomationAction {
  ENVIAR_NOTIFICACION
  CREAR_AUDITORIA
  CAMBIAR_ESTADO_TAREA
}

enum ObjectiveScope {
  EQUIPO
  PROYECTO
}

enum WebhookEvent {
  TAREA_COMPLETADA
  SOLICITUD_APROBADA
  SOLICITUD_RECHAZADA
  TAREA_REASIGNADA
  TAREA_VENCIDA
}

enum ImportSource {
  CSV
  TRELLO_JSON
  NOTION_CSV
}

enum TaskCodeField {
  TASK_DESCRIPTION
  TASK_BLOCKED_REASON
  TASK_STATUS_REASON
  TASK_REASSIGN_REASON
  TASK_SCHEDULE_REASON
}

enum ProjectCodeField {
  PROJECT_DESCRIPTION
}

enum TeamCodeField {
  TEAM_DESCRIPTION
}

enum MeetingCodeField {
  MEETING_DESCRIPTION
  MEETING_AGREEMENT_DESCRIPTION
}

enum ObjectiveCodeField {
  OBJECTIVE_DESCRIPTION
}

enum DecisionCodeField {
  DECISION_DESCRIPTION
}

enum IdentityCodeField {
  OFFBOARDING_REASON
}

enum AuditCodeField {
  AUDIT_REASON
}

enum GuestResourceType {
  PROYECTO
  ARCHIVO
  DOCUMENTO
}

enum StorageQuotaScope {
  USUARIO
  EQUIPO
}

model User {
  id            String     @id @default(uuid()) @db.Uuid
  email         String     @unique
  passwordHash  String
  firstName     String
  lastName      String
  baseRole      SystemRole @default(COLABORADOR)
  isActive      Boolean    @default(true)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  deactivatedAt DateTime?

  teamMemberships                      TeamMember[]
  projectMemberships                   ProjectMember[]
  projectTeamLinksCreated              ProjectTeamLink[]              @relation("ProjectTeamLinkCreator")
  createdProjects                      Project[]                      @relation("ProjectOwner")
  assignedTasks                        Task[]                         @relation("TaskAssignee")
  createdTasks                         Task[]                         @relation("TaskCreator")
  statusChangedTasks                   TaskStatusHistory[]            @relation("TaskStatusChangedBy")
  taskReassignments                    TaskReassignment[]             @relation("TaskReassignedBy")
  taskScheduleChanges                  TaskScheduleHistory[]          @relation("TaskScheduleChangedBy")
  onboardingRuns                       OnboardingRun[]                @relation("OnboardedUser")
  offboardingRecords                   OffboardingRecord[]            @relation("OffboardedUser")
  offboardingTransfers                 OffboardingRecord[]            @relation("OffboardingTransferUser")
  guestInvitesCreated                  GuestInvite[]                  @relation("GuestInviteCreator")
  internalInvitesCreated               InternalInvite[]               @relation("InternalInviteCreator")
  personProfile                        PersonProfile?
  availabilityBlocks                   AvailabilityBlock[]
  workSchedule                         WorkSchedule?
  timeEntries                          TimeEntry[]
  channelMemberships                   ChannelMember[]
  messages                             Message[]
  createdMeetings                      Meeting[]                      @relation("MeetingCreator")
  meetingParticipants                  MeetingParticipant[]
  meetingNotes                         MeetingNote[]                  @relation("MeetingNoteAuthor")
  meetingAgreements                    MeetingAgreement[]             @relation("MeetingAgreementAuthor")
  externalCalendarConnections          ExternalCalendarConnection[]
  notificationPreferences              NotificationPreference[]
  notifications                        Notification[]
  announcementsCreated                 Announcement[]                 @relation("AnnouncementCreator")
  announcementsAudience                AnnouncementUser[]
  formRequests                         FormRequest[]                  @relation("FormRequester")
  formApprovals                        FormRequest[]                  @relation("FormApprover")
  foldersCreated                       Folder[]                       @relation("FolderCreator")
  filesCreated                         FileObject[]                   @relation("FileOwner")
  createdCollaborativeDocuments        CollaborativeDocument[]        @relation("DocumentCreator")
  createdCollaborativeDocumentVersions CollaborativeDocumentVersion[] @relation("DocumentVersionCreator")
  createdDocumentAssets                DocumentAsset[]                @relation("DocumentAssetCreator")
  decisionNotes                        DecisionNote[]                 @relation("DecisionAuthor")
  automationRulesCreated               AutomationRule[]               @relation("AutomationCreator")
  objectivesOwned                      Objective[]                    @relation("ObjectiveOwner")
  refreshTokens                        RefreshToken[]
  auditLogs                            AuditLog[]
  webhookEndpointsCreated              WebhookEndpoint[]              @relation("WebhookCreator")
  importJobsCreated                    ImportJob[]                    @relation("ImportCreator")

  @@index([baseRole])
  @@index([isActive])
}

model Team {
  id              String   @id @default(uuid()) @db.Uuid
  name            String   @unique
  description     String?
  descriptionCode String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  members                TeamMember[]
  channels               Channel[]
  folders                Folder[]
  meetings               Meeting[]
  externalCalendarEvents ExternalCalendarEvent[]
  announcements          AnnouncementTeam[]
  objectives             Objective[]
  internalInvites        InternalInvite[]
  projectLinks           ProjectTeamLink[]

  @@index([name])
  @@index([descriptionCode])
}

model TeamMember {
  id        String   @id @default(uuid()) @db.Uuid
  teamId    String   @db.Uuid
  userId    String   @db.Uuid
  createdAt DateTime @default(now())

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
  @@index([teamId])
  @@index([userId])
}

model Project {
  id              String          @id @default(uuid()) @db.Uuid
  name            String
  description     String?
  descriptionCode String?
  template        ProjectTemplate
  ownerId         String          @db.Uuid
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  owner                  User                    @relation("ProjectOwner", fields: [ownerId], references: [id])
  members                ProjectMember[]
  tasks                  Task[]
  meetings               Meeting[]
  externalCalendarEvents ExternalCalendarEvent[]
  channels               Channel[]
  folders                Folder[]
  collaborativeDocuments CollaborativeDocument[]
  documentSpace          ProjectDocumentSpace?
  automationRules        AutomationRule[]
  objectives             Objective[]
  stages                 ProjectStage[]
  teamLinks              ProjectTeamLink[]

  @@index([ownerId])
  @@index([template])
  @@index([descriptionCode])
}

model ProjectMember {
  id               String                  @id @default(uuid()) @db.Uuid
  projectId        String                  @db.Uuid
  userId           String                  @db.Uuid
  role             SystemRole
  membershipSource ProjectMembershipSource @default(MANUAL)
  syncTeamsCount   Int                     @default(0)
  joinedAt         DateTime                @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
  @@index([projectId])
  @@index([userId])
  @@index([role])
  @@index([membershipSource])
}

model ProjectTeamLink {
  id          String   @id @default(uuid()) @db.Uuid
  projectId   String   @db.Uuid
  teamId      String   @db.Uuid
  createdById String   @db.Uuid
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  team      Team    @relation(fields: [teamId], references: [id], onDelete: Cascade)
  createdBy User    @relation("ProjectTeamLinkCreator", fields: [createdById], references: [id])

  @@unique([projectId, teamId])
  @@index([projectId])
  @@index([teamId])
  @@index([createdById])
}

model Task {
  id                 String     @id @default(uuid()) @db.Uuid
  projectId          String     @db.Uuid
  stageId            String?    @db.Uuid
  title              String
  description        String?
  descriptionCode    String?
  assigneeId         String?    @db.Uuid
  createdById        String     @db.Uuid
  status             TaskStatus @default(PENDIENTE)
  pendingActivatedAt DateTime?
  startDate          DateTime?
  dueDate            DateTime?
  blockingTaskId     String?    @db.Uuid
  blockedReason      String?
  blockedReasonCode  String?
  completedAt        DateTime?
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt

  project           Project               @relation(fields: [projectId], references: [id], onDelete: Cascade)
  stage             ProjectStage?         @relation(fields: [stageId], references: [id], onDelete: SetNull)
  assignee          User?                 @relation("TaskAssignee", fields: [assigneeId], references: [id])
  createdBy         User                  @relation("TaskCreator", fields: [createdById], references: [id])
  blockingTask      Task?                 @relation("TaskBlockingSelf", fields: [blockingTaskId], references: [id])
  blockedTasks      Task[]                @relation("TaskBlockingSelf")
  dependencies      TaskDependency[]      @relation("TaskDependencies")
  dependents        TaskDependency[]      @relation("TaskDependents")
  statusHistory     TaskStatusHistory[]
  reassignments     TaskReassignment[]
  timeEntries       TimeEntry[]
  meetingAgreements MeetingAgreement[]
  objectiveLinks    ObjectiveTask[]
  scheduleHistory   TaskScheduleHistory[]

  @@index([projectId])
  @@index([stageId])
  @@index([assigneeId])
  @@index([createdById])
  @@index([status])
  @@index([pendingActivatedAt])
  @@index([startDate])
  @@index([dueDate])
  @@index([blockingTaskId])
  @@index([descriptionCode])
  @@index([blockedReasonCode])
}

model ProjectStage {
  id        String   @id @default(uuid()) @db.Uuid
  projectId String   @db.Uuid
  code      String
  name      String
  color     String   @default("#4F7CFF")
  order     Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tasks   Task[]

  @@unique([projectId, name])
  @@unique([projectId, code])
  @@index([projectId])
  @@index([projectId, order])
}

model TaskDependency {
  id              String   @id @default(uuid()) @db.Uuid
  taskId          String   @db.Uuid
  dependsOnTaskId String   @db.Uuid
  createdAt       DateTime @default(now())

  task          Task @relation("TaskDependencies", fields: [taskId], references: [id], onDelete: Cascade)
  dependsOnTask Task @relation("TaskDependents", fields: [dependsOnTaskId], references: [id], onDelete: Cascade)

  @@unique([taskId, dependsOnTaskId])
  @@index([taskId])
  @@index([dependsOnTaskId])
}

model TaskStatusHistory {
  id          String      @id @default(uuid()) @db.Uuid
  taskId      String      @db.Uuid
  fromStatus  TaskStatus?
  toStatus    TaskStatus
  reason      String
  reasonCode  String?
  changedById String      @db.Uuid
  changedAt   DateTime    @default(now())

  task      Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  changedBy User @relation("TaskStatusChangedBy", fields: [changedById], references: [id])

  @@index([taskId])
  @@index([changedById])
  @@index([changedAt])
  @@index([reasonCode])
}

model TaskReassignment {
  id                 String   @id @default(uuid()) @db.Uuid
  taskId             String   @db.Uuid
  previousAssigneeId String?  @db.Uuid
  newAssigneeId      String   @db.Uuid
  reason             String
  reasonCode         String?
  reassignedById     String   @db.Uuid
  reassignedAt       DateTime @default(now())

  task         Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  reassignedBy User @relation("TaskReassignedBy", fields: [reassignedById], references: [id])

  @@index([taskId])
  @@index([newAssigneeId])
  @@index([reassignedById])
  @@index([reasonCode])
}

model TaskScheduleHistory {
  id                String    @id @default(uuid()) @db.Uuid
  taskId            String    @db.Uuid
  previousStartDate DateTime?
  previousDueDate   DateTime?
  newStartDate      DateTime?
  newDueDate        DateTime?
  reason            String
  reasonCode        String?
  changedById       String    @db.Uuid
  changedAt         DateTime  @default(now())

  task      Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  changedBy User @relation("TaskScheduleChangedBy", fields: [changedById], references: [id])

  @@index([taskId])
  @@index([changedById])
  @@index([changedAt])
  @@index([reasonCode])
}

model OnboardingChecklist {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())

  items OnboardingChecklistItem[]
  runs  OnboardingRun[]
}

model OnboardingChecklistItem {
  id          String  @id @default(uuid()) @db.Uuid
  checklistId String  @db.Uuid
  stepKey     String
  label       String
  required    Boolean @default(true)
  order       Int

  checklist OnboardingChecklist @relation(fields: [checklistId], references: [id], onDelete: Cascade)

  @@unique([checklistId, stepKey])
  @@index([checklistId])
  @@index([order])
}

model OnboardingRun {
  id          String    @id @default(uuid()) @db.Uuid
  checklistId String    @db.Uuid
  userId      String    @db.Uuid
  startedAt   DateTime  @default(now())
  completedAt DateTime?

  checklist OnboardingChecklist @relation(fields: [checklistId], references: [id])
  user      User                @relation("OnboardedUser", fields: [userId], references: [id])
  steps     OnboardingRunStep[]

  @@index([checklistId])
  @@index([userId])
}

model OnboardingRunStep {
  id          String    @id @default(uuid()) @db.Uuid
  runId       String    @db.Uuid
  stepKey     String
  completed   Boolean   @default(false)
  completedAt DateTime?

  run OnboardingRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@unique([runId, stepKey])
  @@index([runId])
}

model OffboardingRecord {
  id               String    @id @default(uuid()) @db.Uuid
  userId           String    @db.Uuid
  transferToUserId String    @db.Uuid
  reason           String
  reasonCode       String?
  revokedAt        DateTime  @default(now())
  archivedAt       DateTime?

  user           User @relation("OffboardedUser", fields: [userId], references: [id])
  transferToUser User @relation("OffboardingTransferUser", fields: [transferToUserId], references: [id])

  @@index([userId])
  @@index([transferToUserId])
  @@index([reasonCode])
}

model GuestInvite {
  id           String            @id @default(uuid()) @db.Uuid
  email        String
  tokenHash    String
  resourceType GuestResourceType
  resourceId   String            @db.Uuid
  expiresAt    DateTime
  createdById  String            @db.Uuid
  acceptedAt   DateTime?
  revokedAt    DateTime?
  createdAt    DateTime          @default(now())

  createdBy User @relation("GuestInviteCreator", fields: [createdById], references: [id])

  @@index([resourceType, resourceId])
  @@index([email])
  @@index([expiresAt])
  @@index([createdById])
}

model InternalInvite {
  id          String     @id @default(uuid()) @db.Uuid
  email       String
  tokenHash   String     @unique
  baseRole    SystemRole
  teamId      String?    @db.Uuid
  expiresAt   DateTime
  createdById String     @db.Uuid
  acceptedAt  DateTime?
  revokedAt   DateTime?
  createdAt   DateTime   @default(now())
  resentAt    DateTime?

  createdBy User  @relation("InternalInviteCreator", fields: [createdById], references: [id])
  team      Team? @relation(fields: [teamId], references: [id], onDelete: SetNull)

  @@index([email])
  @@index([expiresAt])
  @@index([createdById])
  @@index([teamId])
}

model PersonProfile {
  id                   String   @id @default(uuid()) @db.Uuid
  userId               String   @unique @db.Uuid
  internalContactEmail String
  internalPhone        String?
  skills               String[]
  timezone             String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model AvailabilityBlock {
  id        String           @id @default(uuid()) @db.Uuid
  userId    String           @db.Uuid
  type      AvailabilityType
  startAt   DateTime
  endAt     DateTime
  note      String?
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([type])
  @@index([startAt, endAt])
}

model WorkSchedule {
  id                  String   @id @default(uuid()) @db.Uuid
  userId              String   @unique @db.Uuid
  timezone            String
  weekDays            Int[]
  startHour           String
  endHour             String
  maxActiveTasks      Int      @default(5)
  periodHoursCapacity Float    @default(40)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model TimeEntry {
  id       String   @id @default(uuid()) @db.Uuid
  userId   String   @db.Uuid
  taskId   String   @db.Uuid
  minutes  Int
  note     String?
  loggedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([taskId])
  @@index([loggedAt])
}

model Channel {
  id        String       @id @default(uuid()) @db.Uuid
  name      String
  scope     ChannelScope
  teamId    String?      @db.Uuid
  projectId String?      @db.Uuid
  createdAt DateTime     @default(now())

  team     Team?           @relation(fields: [teamId], references: [id])
  project  Project?        @relation(fields: [projectId], references: [id])
  members  ChannelMember[]
  messages Message[]

  @@index([teamId])
  @@index([projectId])
  @@index([scope])
}

model ChannelMember {
  id        String   @id @default(uuid()) @db.Uuid
  channelId String   @db.Uuid
  userId    String   @db.Uuid
  joinedAt  DateTime @default(now())

  channel Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([channelId, userId])
  @@index([channelId])
  @@index([userId])
}

model Message {
  id        String      @id @default(uuid()) @db.Uuid
  channelId String      @db.Uuid
  authorId  String      @db.Uuid
  kind      MessageKind @default(TEXT)
  content   String
  mentions  String[]
  meetingId String?     @db.Uuid
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  channel     Channel             @relation(fields: [channelId], references: [id], onDelete: Cascade)
  author      User                @relation(fields: [authorId], references: [id], onDelete: Cascade)
  meeting     Meeting?            @relation(fields: [meetingId], references: [id], onDelete: SetNull)
  attachments MessageAttachment[]

  @@index([channelId])
  @@index([authorId])
  @@index([kind])
  @@index([meetingId])
  @@index([createdAt])
}

model MessageAttachment {
  id           String   @id @default(uuid()) @db.Uuid
  messageId    String   @db.Uuid
  originalName String
  mimeType     String
  sizeBytes    Int
  minioPath    String
  createdAt    DateTime @default(now())

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([messageId])
  @@index([createdAt])
}

model Meeting {
  id              String        @id @default(uuid()) @db.Uuid
  title           String
  description     String?
  descriptionCode String?
  projectId       String?       @db.Uuid
  teamId          String?       @db.Uuid
  startsAt        DateTime
  endsAt          DateTime
  createdById     String        @db.Uuid
  status          MeetingStatus @default(PROGRAMADA)
  mediaRoomId     String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  project      Project?             @relation(fields: [projectId], references: [id], onDelete: SetNull)
  team         Team?                @relation(fields: [teamId], references: [id], onDelete: SetNull)
  createdBy    User                 @relation("MeetingCreator", fields: [createdById], references: [id])
  participants MeetingParticipant[]
  agendaItems  MeetingAgendaItem[]
  notes        MeetingNote[]
  agreements   MeetingAgreement[]
  messages     Message[]

  @@index([projectId])
  @@index([teamId])
  @@index([createdById])
  @@index([startsAt, endsAt])
  @@index([status])
  @@index([descriptionCode])
}

model MeetingParticipant {
  id            String      @id @default(uuid()) @db.Uuid
  meetingId     String      @db.Uuid
  userId        String      @db.Uuid
  role          SystemRole?
  muted         Boolean     @default(false)
  cameraOn      Boolean     @default(true)
  screenSharing Boolean     @default(false)
  speaking      Boolean     @default(false)
  joinedAt      DateTime?
  leftAt        DateTime?
  createdAt     DateTime    @default(now())

  meeting Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([meetingId, userId])
  @@index([meetingId])
  @@index([userId])
}

model MeetingAgendaItem {
  id        String   @id @default(uuid()) @db.Uuid
  meetingId String   @db.Uuid
  text      String
  order     Int
  createdAt DateTime @default(now())

  meeting Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)

  @@unique([meetingId, order])
  @@index([meetingId])
}

model MeetingNote {
  id        String   @id @default(uuid()) @db.Uuid
  meetingId String   @db.Uuid
  authorId  String   @db.Uuid
  content   Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  meeting Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  author  User    @relation("MeetingNoteAuthor", fields: [authorId], references: [id], onDelete: Cascade)

  @@index([meetingId])
  @@index([authorId])
}

model MeetingAgreement {
  id              String                 @id @default(uuid()) @db.Uuid
  meetingId       String                 @db.Uuid
  title           String
  description     String?
  descriptionCode String?
  status          MeetingAgreementStatus @default(PENDIENTE_ACCION)
  authorId        String                 @db.Uuid
  taskId          String?                @db.Uuid
  createdTask     Boolean                @default(false)
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt

