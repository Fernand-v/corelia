generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TaskStatus {
  PENDIENTE
  EN_REVISION
  COMPLETADA
}

enum ProjectTemplate {
  SOFTWARE
  CONTENIDO
  OPERACIONES
}

enum ProjectMembershipSource {
  MANUAL
  SYNC
}

enum AvailabilityType {
  VACACIONES
  PERMISO
  AUSENCIA
  NO_DISPONIBLE
}

enum NotificationChannel {
  EMAIL
  IN_APP
}

enum NotificationFrequency {
  INMEDIATA
  RESUMEN_DIARIO
}

enum NotificationEvent {
  TAREA_ASIGNADA
  TAREA_REASIGNADA
  TAREA_ESTADO_CAMBIADO
  MENSAJE_NUEVO_CANAL
  MENCION_MENSAJE
  REUNION_PROGRAMADA
  ACUERDO_ASIGNADO_TAREA
  TAREA_PROXIMA_VENCER
  TAREA_BLOQUEADA
  SOLICITUD_RESUELTA
  TICKET_CREADO
  TICKET_ACTUALIZADO
  TICKET_COMENTARIO
}

enum NotificationPriority {
  NORMAL
  URGENTE
}

enum RequestType {
  VACACIONES
  PERMISO
  ACCESO_RECURSO
}

enum RequestStatus {
  PENDIENTE
  APROBADA
  RECHAZADA
}

enum DynamicFormQuestionType {
  short_text
  long_text
  multiple_choice
  checkbox
  rating
  date
  nps
  file_upload
}

enum ChannelScope {
  EQUIPO
  PROYECTO
}

enum MessageKind {
  TEXT
  FILE
  CALL_INVITE
  NOTA_VOZ
  LLAMADA_PERDIDA
  LLAMADA_FINALIZADA
}

enum MeetingCallType {
  VIDEO
  VOZ
}

enum DocumentType {
  TEXTO
  DIAGRAMA
  TABLA
  WHITEBOARD
  PRESENTACION
}

enum DiagramEngine {
  EXCALIDRAW
  REACT_FLOW
}

enum DiagramKind {
  FLUJO
  SECUENCIA
  UML_CLASES
  ENTIDAD_RELACION
  ESTADO
  ARQUITECTURA
  BPMN
}

enum DocumentVersionKind {
  MANUAL
  AUTO
}

enum DocumentCollabSessionStatus {
  ACTIVE
  CLOSED
}

enum DocumentCollabParticipantStatus {
  ONLINE
  OFFLINE
}

enum DocumentCollabEventType {
  JOIN
  LEAVE
  DISCONNECT
  RECONNECT
  SNAPSHOT_SAVED
  SAVE_VERSION
  ERROR
  MIGRATION
}

enum FolderScope {
  EQUIPO
  PROYECTO
}

enum ExpenseStatus {
  PENDIENTE
  APROBADO
  RECHAZADO
}

enum ActionType {
  LOGIN
  LOGOUT
  CREAR
  ACTUALIZAR
  ELIMINAR
  PROGRAMAR_REUNION
  REGISTRAR_ACUERDO
  CAMBIO_ROL
  CAMBIO_ESTADO_TAREA
  REASIGNAR_TAREA
  APROBAR_SOLICITUD
  CAMBIO_PERMISO
}

enum MeetingStatus {
  PROGRAMADA
  EN_CURSO
  FINALIZADA
  CANCELADA
}

enum MeetingAgreementStatus {
  PENDIENTE_ACCION
  VINCULADO_TAREA
  COMPLETADO
}

enum ExternalCalendarProvider {
  GOOGLE
  MICROSOFT
}

enum AutomationEvent {
  TAREA_COMPLETADA
  TAREA_SIN_MOVIMIENTO
  TAREA_REASIGNADA
  TAREA_VENCIDA
  SOLICITUD_RESUELTA
}

enum AutomationAction {
  ENVIAR_NOTIFICACION
  CREAR_AUDITORIA
  CAMBIAR_ESTADO_TAREA
}

enum ObjectiveScope {
  EQUIPO
  PROYECTO
}

enum WebhookEvent {
  TAREA_COMPLETADA
  SOLICITUD_APROBADA
  SOLICITUD_RECHAZADA
  TAREA_REASIGNADA
  TAREA_VENCIDA
}

enum ImportSource {
  CSV
  TRELLO_JSON
  NOTION_CSV
}

enum TaskCodeField {
  TASK_DESCRIPTION
  TASK_BLOCKED_REASON
  TASK_STATUS_REASON
  TASK_REASSIGN_REASON
  TASK_SCHEDULE_REASON
}

enum ProjectCodeField {
  PROJECT_DESCRIPTION
}

enum TeamCodeField {
  TEAM_DESCRIPTION
}

enum MeetingCodeField {
  MEETING_DESCRIPTION
  MEETING_AGREEMENT_DESCRIPTION
}

enum ObjectiveCodeField {
  OBJECTIVE_DESCRIPTION
}

enum DecisionCodeField {
  DECISION_DESCRIPTION
}

enum IdentityCodeField {
  OFFBOARDING_REASON
}

enum AuditCodeField {
  AUDIT_REASON
}

enum GuestResourceType {
  PROYECTO
  ARCHIVO
  DOCUMENTO
}

enum SignupRequestStatus {
  PENDIENTE
  APROBADA
  RECHAZADA
}

enum StorageQuotaScope {
  USUARIO
  EQUIPO
}

enum RoleScope {
  GLOBAL
  PROJECT
}

model PermissionCategory {
  id          String   @id @default(uuid()) @db.Uuid
  code        Int      @default(autoincrement()) @unique
  key         String   @unique
  displayName String
  description String?
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  permissions Permission[]

  @@index([sortOrder])
}

model Program {
  id          String   @id @default(uuid()) @db.Uuid
  code        Int      @default(autoincrement()) @unique
  key         String   @unique
  displayName String
  description String?
  sortOrder   Int      @default(0)
  isSystem    Boolean  @default(false)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  permissions Permission[]
  programRoles ProgramRole[]

  @@index([sortOrder])
  @@index([isActive])
}

model Resource {
  id          String   @id @default(uuid()) @db.Uuid
  code        Int      @default(autoincrement()) @unique
  key         String   @unique
  displayName String
  description String?
  sortOrder   Int      @default(0)
  isSystem    Boolean  @default(false)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  permissions Permission[]

  @@index([sortOrder])
  @@index([isActive])
}

model Action {
  id          String   @id @default(uuid()) @db.Uuid
  code        Int      @default(autoincrement()) @unique
  key         String   @unique
  displayName String
  description String?
  kind        String   @default("write")
  sortOrder   Int      @default(0)
  isSystem    Boolean  @default(false)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  permissions Permission[]

  @@index([sortOrder])
  @@index([isActive])
}

model Permission {
  id          String   @id @default(uuid()) @db.Uuid
  code        Int      @default(autoincrement()) @unique
  key         String   @unique
  displayName String
  description String?
  programId   String   @db.Uuid
  categoryId  String   @db.Uuid
  resourceId  String   @db.Uuid
  actionId    String   @db.Uuid
  isSystem    Boolean  @default(false)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  program         Program            @relation(fields: [programId], references: [id], onDelete: Restrict)
  category        PermissionCategory @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  resource        Resource           @relation(fields: [resourceId], references: [id], onDelete: Restrict)
  action          Action             @relation(fields: [actionId], references: [id], onDelete: Restrict)
  rolePermissions RolePermission[]

  @@unique([resourceId, actionId])
  @@index([programId])
  @@index([categoryId])
  @@index([resourceId])
  @@index([actionId])
  @@index([isActive])
}

model Role {
  id          String    @id @default(uuid()) @db.Uuid
  code        Int       @default(autoincrement()) @unique
  key         String    @unique
  displayName String
  description String?
  isSystem    Boolean   @default(false)
  scope       RoleScope @default(PROJECT)
  rank        Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  usersBaseRole       User[]               @relation("UserBaseRole")
  projectMembers      ProjectMember[]      @relation("ProjectMemberRole")
  internalInvites     InternalInvite[]     @relation("InternalInviteBaseRole")
  meetingParticipants MeetingParticipant[] @relation("MeetingParticipantRole")
  rolePermissions     RolePermission[]
  programRoles        ProgramRole[]

  @@index([isSystem])
  @@index([scope])
}

model RolePermission {
  roleId       String   @db.Uuid
  permissionId String   @db.Uuid
  createdAt    DateTime @default(now())

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@index([permissionId])
}

model ProgramRole {
  programId  String   @db.Uuid
  roleId     String   @db.Uuid
  createdAt  DateTime @default(now())

  program Program @relation(fields: [programId], references: [id], onDelete: Cascade)
  role    Role    @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([programId, roleId])
  @@index([roleId])
}

model User {
  id            String     @id @default(uuid()) @db.Uuid
  email         String     @unique
  passwordHash  String
  firstName     String
  lastName      String
  baseRoleId    String     @db.Uuid
  isActive      Boolean    @default(true)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  deactivatedAt DateTime?

  teamMemberships                      TeamMember[]
  projectMemberships                   ProjectMember[]
  projectTeamLinksCreated              ProjectTeamLink[]              @relation("ProjectTeamLinkCreator")
  createdProjects                      Project[]                      @relation("ProjectOwner")
  baseRole                            Role                           @relation("UserBaseRole", fields: [baseRoleId], references: [id], onDelete: Restrict)
  assignedTasks                        Task[]                         @relation("TaskAssignee")
  createdTasks                         Task[]                         @relation("TaskCreator")
  statusChangedTasks                   TaskStatusHistory[]            @relation("TaskStatusChangedBy")
  taskReassignments                    TaskReassignment[]             @relation("TaskReassignedBy")
  taskScheduleChanges                  TaskScheduleHistory[]          @relation("TaskScheduleChangedBy")
  onboardingRuns                       OnboardingRun[]                @relation("OnboardedUser")
  offboardingRecords                   OffboardingRecord[]            @relation("OffboardedUser")
  offboardingTransfers                 OffboardingRecord[]            @relation("OffboardingTransferUser")
  guestInvitesCreated                  GuestInvite[]                  @relation("GuestInviteCreator")
  internalInvitesCreated               InternalInvite[]               @relation("InternalInviteCreator")
  personProfile                        PersonProfile?
  availabilityBlocks                   AvailabilityBlock[]
  workSchedule                         WorkSchedule?
  timeEntries                          TimeEntry[]
  channelMemberships                   ChannelMember[]
  messages                             Message[]
  createdMeetings                      Meeting[]                      @relation("MeetingCreator")
  meetingParticipants                  MeetingParticipant[]
  meetingNotes                         MeetingNote[]                  @relation("MeetingNoteAuthor")
  meetingAgreements                    MeetingAgreement[]             @relation("MeetingAgreementAuthor")
  externalCalendarConnections          ExternalCalendarConnection[]
  notificationPreferences              NotificationPreference[]
  notifications                        Notification[]
  browserPushSubscriptions             BrowserPushSubscription[]
  announcementsCreated                 Announcement[]                 @relation("AnnouncementCreator")
  announcementsAudience                AnnouncementUser[]
  formRequests                         FormRequest[]                  @relation("FormRequester")
  formApprovals                        FormRequest[]                  @relation("FormApprover")
  foldersCreated                       Folder[]                       @relation("FolderCreator")
  filesCreated                         FileObject[]                   @relation("FileOwner")
  createdCollaborativeDocuments        CollaborativeDocument[]        @relation("DocumentCreator")
  createdCollaborativeDocumentVersions CollaborativeDocumentVersion[] @relation("DocumentVersionCreator")
  createdDocumentAssets                DocumentAsset[]                @relation("DocumentAssetCreator")
  documentFavorites                    DocumentFavorite[]             @relation("DocumentFavoriteUser")
  createdDocumentTemplates             DocumentTemplate[]             @relation("DocumentTemplateCreator")
  documentCollabParticipants           DocumentCollabParticipant[]    @relation("DocumentCollabParticipantUser")
  documentCollabEvents                 DocumentCollabEvent[]          @relation("DocumentCollabEventUser")
  decisionNotes                        DecisionNote[]                 @relation("DecisionAuthor")
  decisionNotesLinkedUser              DecisionNote[]                 @relation("DecisionLinkedUser")
  automationRulesCreated               AutomationRule[]               @relation("AutomationCreator")
  objectivesOwned                      Objective[]                    @relation("ObjectiveOwner")
  refreshTokens                        RefreshToken[]
  auditLogs                            AuditLog[]
  auditLogsTargetUser                  AuditLog[]                     @relation("AuditTargetUser")
  webhookEndpointsCreated              WebhookEndpoint[]              @relation("WebhookCreator")
  importJobsCreated                    ImportJob[]                    @relation("ImportCreator")
  projectDetailsCreated                ProjectDetail[]                @relation("ProjectDetailCreator")
  expensesCreated                      Expense[]                      @relation("ExpenseCreator")
  expensesApproved                     Expense[]                      @relation("ExpenseApprover")
  storageQuotaUser                     StorageQuota?                  @relation("StorageQuotaUser")
  reviewedSignupRequests               SignupRequest[]                @relation("SignupRequestReviewer")
  createdDynamicForms                  DynamicForm[]                  @relation("DynamicFormCreator")
  dynamicFormResponses                 DynamicFormResponse[]          @relation("DynamicFormResponder")
  messageReceipts                      MessageReceipt[]
  ticketsAsignados                     Ticket[]                       @relation("TicketAssignee")
  ticketsCreados                       Ticket[]                       @relation("TicketCreator")
  ticketComments                       TicketComment[]                @relation("TicketCommentAuthor")

  @@index([baseRoleId])
  @@index([isActive])
}

model Team {
  id                   String   @id @default(uuid()) @db.Uuid
  name                 String   @unique
  description          String?
  descriptionCatalogId String?  @db.Uuid
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  members                TeamMember[]
  channels               Channel[]
  folders                Folder[]
  meetings               Meeting[]
  externalCalendarEvents ExternalCalendarEvent[]
  announcements          AnnouncementTeam[]
  objectives             Objective[]
  internalInvites        InternalInvite[]
  projectLinks           ProjectTeamLink[]
  descriptionCatalog     TeamCodeCatalog? @relation("TeamDescriptionCatalog", fields: [descriptionCatalogId], references: [id], onDelete: SetNull)
  storageQuotaTeam       StorageQuota?      @relation("StorageQuotaTeam")

  @@index([name])
  @@index([descriptionCatalogId])
}

model TeamMember {
  id        String   @id @default(uuid()) @db.Uuid
  teamId    String   @db.Uuid
  userId    String   @db.Uuid
  createdAt DateTime @default(now())

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
  @@index([teamId])
  @@index([userId])
}

model Project {
  id                   String          @id @default(uuid()) @db.Uuid
  name                 String
  description          String?
  descriptionCatalogId String?         @db.Uuid
  template             ProjectTemplate
  ownerId              String          @db.Uuid
  startDate            DateTime?
  estimatedEndDate     DateTime?
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt

  owner                  User                    @relation("ProjectOwner", fields: [ownerId], references: [id])
  descriptionCatalog     ProjectCodeCatalog?     @relation("ProjectDescriptionCatalog", fields: [descriptionCatalogId], references: [id], onDelete: SetNull)
  members                ProjectMember[]
  tasks                  Task[]
  meetings               Meeting[]
  externalCalendarEvents ExternalCalendarEvent[]
  channels               Channel[]
  folders                Folder[]
  collaborativeDocuments CollaborativeDocument[]
  documentSpace          ProjectDocumentSpace?
  automationRules        AutomationRule[]
  objectives             Objective[]
  stages                 ProjectStage[]
  teamLinks              ProjectTeamLink[]
  details                ProjectDetail[]
  guestInvites           GuestInvite[]              @relation("GuestInviteProject")
  documentTemplates      DocumentTemplate[]
  decisionNotesLinkedProject DecisionNote[]          @relation("DecisionLinkedProject")
  auditLogsTargetProject AuditLog[]                  @relation("AuditTargetProject")
  dynamicForms           DynamicForm[]

  @@index([ownerId])
  @@index([template])
  @@index([descriptionCatalogId])
}

model ProjectMember {
  id               String                  @id @default(uuid()) @db.Uuid
  projectId        String                  @db.Uuid
  userId           String                  @db.Uuid
  roleId           String                  @db.Uuid
  membershipSource ProjectMembershipSource @default(MANUAL)
  syncTeamsCount   Int                     @default(0)
  joinedAt         DateTime                @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  role    Role    @relation("ProjectMemberRole", fields: [roleId], references: [id], onDelete: Restrict)

  @@unique([projectId, userId])
  @@index([projectId])
  @@index([userId])
  @@index([roleId])
  @@index([membershipSource])
}

model ProjectTeamLink {
  id          String   @id @default(uuid()) @db.Uuid
  projectId   String   @db.Uuid
  teamId      String   @db.Uuid
  createdById String   @db.Uuid
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  team      Team    @relation(fields: [teamId], references: [id], onDelete: Cascade)
  createdBy User    @relation("ProjectTeamLinkCreator", fields: [createdById], references: [id])

  @@unique([projectId, teamId])
  @@index([projectId])
  @@index([teamId])
  @@index([createdById])
}

model Task {
  id                     String     @id @default(uuid()) @db.Uuid
  projectId              String     @db.Uuid
  stageId                String?    @db.Uuid
  title                  String
  description            String?
  descriptionCatalogId   String?    @db.Uuid
  assigneeId             String?    @db.Uuid
  createdById            String     @db.Uuid
  status                 TaskStatus @default(PENDIENTE)
  pendingActivatedAt     DateTime?
  startDate              DateTime?
  dueDate                DateTime?
  blockingTaskId         String?    @db.Uuid
  blockedReason          String?
  blockedReasonCatalogId String?    @db.Uuid
  completedAt            DateTime?
  createdAt              DateTime   @default(now())
  updatedAt              DateTime   @updatedAt

  project              Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  stage                ProjectStage?    @relation(fields: [stageId], references: [id], onDelete: SetNull)
  assignee             User?            @relation("TaskAssignee", fields: [assigneeId], references: [id])
  createdBy            User             @relation("TaskCreator", fields: [createdById], references: [id])
  descriptionCatalog   TaskCodeCatalog? @relation("TaskDescriptionCatalog", fields: [descriptionCatalogId], references: [id], onDelete: SetNull)
  blockedReasonCatalog TaskCodeCatalog? @relation("TaskBlockedReasonCatalog", fields: [blockedReasonCatalogId], references: [id], onDelete: SetNull)
  blockingTask         Task?            @relation("TaskBlockingSelf", fields: [blockingTaskId], references: [id])
  blockedTasks         Task[]           @relation("TaskBlockingSelf")
  dependencies         TaskDependency[] @relation("TaskDependencies")
  dependents           TaskDependency[] @relation("TaskDependents")
  statusHistory        TaskStatusHistory[]
  reassignments        TaskReassignment[]
  timeEntries          TimeEntry[]
  meetingAgreements    MeetingAgreement[]
  objectiveLinks       ObjectiveTask[]
  scheduleHistory      TaskScheduleHistory[]
  decisionNotesLinkedTask DecisionNote[] @relation("DecisionLinkedTask")
  auditLogsTargetTask    AuditLog[]      @relation("AuditTargetTask")

  @@index([projectId])
  @@index([stageId])
  @@index([assigneeId])
  @@index([createdById])
  @@index([status])
  @@index([pendingActivatedAt])
  @@index([startDate])
  @@index([dueDate])
  @@index([blockingTaskId])
  @@index([descriptionCatalogId])
  @@index([blockedReasonCatalogId])
}

model ProjectStage {
  id        String   @id @default(uuid()) @db.Uuid
  projectId String   @db.Uuid
  code      Int      @default(autoincrement())
  name      String
  color     String   @default("#4F7CFF")
  order     Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tasks   Task[]

  @@unique([projectId, name])
  @@unique([projectId, code])
  @@index([projectId])
  @@index([projectId, order])
}

model TaskDependency {
  id              String   @id @default(uuid()) @db.Uuid
  taskId          String   @db.Uuid
  dependsOnTaskId String   @db.Uuid
  createdAt       DateTime @default(now())

  task          Task @relation("TaskDependencies", fields: [taskId], references: [id], onDelete: Cascade)
  dependsOnTask Task @relation("TaskDependents", fields: [dependsOnTaskId], references: [id], onDelete: Cascade)

  @@unique([taskId, dependsOnTaskId])
  @@index([taskId])
  @@index([dependsOnTaskId])
}

model TaskStatusHistory {
  id              String      @id @default(uuid()) @db.Uuid
  taskId          String      @db.Uuid
  fromStatus      TaskStatus?
  toStatus        TaskStatus
  reason          String
  reasonCatalogId String?     @db.Uuid
  changedById     String      @db.Uuid
  changedAt       DateTime    @default(now())

  task          Task             @relation(fields: [taskId], references: [id], onDelete: Cascade)
  changedBy     User             @relation("TaskStatusChangedBy", fields: [changedById], references: [id])
  reasonCatalog TaskCodeCatalog? @relation("TaskStatusReasonCatalog", fields: [reasonCatalogId], references: [id], onDelete: SetNull)

  @@index([taskId])
  @@index([changedById])
  @@index([changedAt])
  @@index([reasonCatalogId])
}

model TaskReassignment {
  id                 String   @id @default(uuid()) @db.Uuid
  taskId             String   @db.Uuid
  previousAssigneeId String?  @db.Uuid
  newAssigneeId      String   @db.Uuid
  reason             String
  reasonCatalogId    String?  @db.Uuid
  reassignedById     String   @db.Uuid
  reassignedAt       DateTime @default(now())

  task          Task             @relation(fields: [taskId], references: [id], onDelete: Cascade)
  reassignedBy  User             @relation("TaskReassignedBy", fields: [reassignedById], references: [id])
  reasonCatalog TaskCodeCatalog? @relation("TaskReassignmentReasonCatalog", fields: [reasonCatalogId], references: [id], onDelete: SetNull)

  @@index([taskId])
  @@index([newAssigneeId])
  @@index([reassignedById])
  @@index([reasonCatalogId])
}

model TaskScheduleHistory {
  id                String    @id @default(uuid()) @db.Uuid
  taskId            String    @db.Uuid
  previousStartDate DateTime?
  previousDueDate   DateTime?
  newStartDate      DateTime?
  newDueDate        DateTime?
  reason            String
  reasonCatalogId   String?   @db.Uuid
  changedById       String    @db.Uuid
  changedAt         DateTime  @default(now())

  task          Task             @relation(fields: [taskId], references: [id], onDelete: Cascade)
  changedBy     User             @relation("TaskScheduleChangedBy", fields: [changedById], references: [id])
  reasonCatalog TaskCodeCatalog? @relation("TaskScheduleReasonCatalog", fields: [reasonCatalogId], references: [id], onDelete: SetNull)

  @@index([taskId])
  @@index([changedById])
  @@index([changedAt])
  @@index([reasonCatalogId])
}

model OnboardingChecklist {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())

  items OnboardingChecklistItem[]
  runs  OnboardingRun[]
}

model OnboardingChecklistItem {
  id          String  @id @default(uuid()) @db.Uuid
  checklistId String  @db.Uuid
  stepKey     String
  label       String
  required    Boolean @default(true)
  order       Int

  checklist OnboardingChecklist @relation(fields: [checklistId], references: [id], onDelete: Cascade)

  @@unique([checklistId, stepKey])
  @@index([checklistId])
  @@index([order])
}

model OnboardingRun {
  id          String    @id @default(uuid()) @db.Uuid
  checklistId String    @db.Uuid
  userId      String    @db.Uuid
  startedAt   DateTime  @default(now())
  completedAt DateTime?

  checklist OnboardingChecklist @relation(fields: [checklistId], references: [id])
  user      User                @relation("OnboardedUser", fields: [userId], references: [id])
  steps     OnboardingRunStep[]

  @@index([checklistId])
  @@index([userId])
}

model OnboardingRunStep {
  id          String    @id @default(uuid()) @db.Uuid
  runId       String    @db.Uuid
  stepKey     String
  completed   Boolean   @default(false)
  completedAt DateTime?

  run OnboardingRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@unique([runId, stepKey])
  @@index([runId])
}

model OffboardingRecord {
  id               String    @id @default(uuid()) @db.Uuid
  userId           String    @db.Uuid
  transferToUserId String    @db.Uuid
  reason           String
  reasonCatalogId  String?   @db.Uuid
  revokedAt        DateTime  @default(now())
  archivedAt       DateTime?

  user           User                 @relation("OffboardedUser", fields: [userId], references: [id])
  transferToUser User                 @relation("OffboardingTransferUser", fields: [transferToUserId], references: [id])
  reasonCatalog  IdentityCodeCatalog? @relation("OffboardingReasonCatalog", fields: [reasonCatalogId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([transferToUserId])
  @@index([reasonCatalogId])
}

model GuestInvite {
  id           String   @id @default(uuid()) @db.Uuid
  email        String
  tokenHash    String
