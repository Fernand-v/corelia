model AuditLog {
  id              String     @id @default(uuid()) @db.Uuid
  targetUserId             String?    @db.Uuid
  targetProjectId          String?    @db.Uuid
  targetTaskId             String?    @db.Uuid
  targetMeetingId          String?    @db.Uuid
  targetMeetingAgreementId String?    @db.Uuid
  targetMessageId          String?    @db.Uuid
  targetFileId             String?    @db.Uuid
  targetFormRequestId      String?    @db.Uuid
  targetAnnouncementId     String?    @db.Uuid
  targetObjectiveId        String?    @db.Uuid
  targetDecisionId         String?    @db.Uuid
  targetAutomationRuleId   String?    @db.Uuid
  targetExpenseId          String?    @db.Uuid
  action           ActionType
  userId           String?    @db.Uuid
  previousDataText String?
  newDataText      String?
  reason           String?
  reasonCatalogId  String?    @db.Uuid
  createdAt        DateTime   @default(now())

  user          User?             @relation(fields: [userId], references: [id])
  reasonCatalog AuditCodeCatalog? @relation("AuditReasonCatalog", fields: [reasonCatalogId], references: [id], onDelete: SetNull)
  targetUser         User?             @relation("AuditTargetUser", fields: [targetUserId], references: [id], onDelete: SetNull)
  targetProject      Project?          @relation("AuditTargetProject", fields: [targetProjectId], references: [id], onDelete: SetNull)
  targetTask         Task?             @relation("AuditTargetTask", fields: [targetTaskId], references: [id], onDelete: SetNull)
  targetMeeting      Meeting?          @relation("AuditTargetMeeting", fields: [targetMeetingId], references: [id], onDelete: SetNull)
  targetMeetingAgreement MeetingAgreement? @relation("AuditTargetMeetingAgreement", fields: [targetMeetingAgreementId], references: [id], onDelete: SetNull)
  targetMessage      Message?          @relation("AuditTargetMessage", fields: [targetMessageId], references: [id], onDelete: SetNull)
  targetFile         FileObject?       @relation("AuditTargetFile", fields: [targetFileId], references: [id], onDelete: SetNull)
  targetFormRequest  FormRequest?      @relation("AuditTargetFormRequest", fields: [targetFormRequestId], references: [id], onDelete: SetNull)
  targetAnnouncement Announcement?     @relation("AuditTargetAnnouncement", fields: [targetAnnouncementId], references: [id], onDelete: SetNull)
  targetObjective    Objective?        @relation("AuditTargetObjective", fields: [targetObjectiveId], references: [id], onDelete: SetNull)
  targetDecision     DecisionNote?     @relation("AuditTargetDecision", fields: [targetDecisionId], references: [id], onDelete: SetNull)
  targetAutomationRule AutomationRule? @relation("AuditTargetAutomationRule", fields: [targetAutomationRuleId], references: [id], onDelete: SetNull)
  targetExpense      Expense?          @relation("AuditTargetExpense", fields: [targetExpenseId], references: [id], onDelete: SetNull)

  @@index([action])
  @@index([userId])
  @@index([createdAt])
  @@index([reasonCatalogId])
  @@index([targetUserId])
  @@index([targetProjectId])
  @@index([targetTaskId])
  @@index([targetMeetingId])
  @@index([targetMeetingAgreementId])
  @@index([targetMessageId])
  @@index([targetFileId])
  @@index([targetFormRequestId])
  @@index([targetAnnouncementId])
  @@index([targetObjectiveId])
  @@index([targetDecisionId])
  @@index([targetAutomationRuleId])
  @@index([targetExpenseId])
}

