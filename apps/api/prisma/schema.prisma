model CollaborativeDocument {
  id             String       @id @default(uuid()) @db.Uuid
  projectId      String       @db.Uuid
  folderId       String       @db.Uuid
  type           DocumentType
  name           String
  yDocName       String       @unique
  diagramEngine  DiagramEngine?
  diagramKind    DiagramKind?
