{
  "extends": "@corelia/config/tsconfig.node",
  "compilerOptions": {
    "composite": true,
    "outDir": "dist",
    "rootDir": "src",
    "baseUrl": ".",
    "strict": false,
    "exactOptionalPropertyTypes": false,
    "paths": {
      "@/*": ["src/*"]
    },
    "tsBuildInfoFile": "dist/tsconfig.tsbuildinfo"
  },
  "include": ["src/**/*.ts"]
}
