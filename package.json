{
  "name": "corelia",
  "private": true,
  "version": "0.1.0",
  "description": "Corelia intranet monorepo",
  "packageManager": "pnpm@9.12.3",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "test:db": "bash scripts/test-db.sh",
    "typecheck": "turbo run typecheck",
    "format": "turbo run format",
    "verify:peers-caller-patch": "node scripts/check-peers-caller-patch.mjs",
    "security:audit": "corepack pnpm audit --prod --audit-level=high",
    "security:check-compose": "bash scripts/check-compose-secrets.sh",
    "security:check-unsafe-casts": "bash scripts/check-unsafe-casts.sh",
    "preflight:docker": "bash scripts/preflight-docker.sh",
    "data:demo": "corepack pnpm --filter @corelia/api exec tsx ../../scripts/generate-demo-data.ts",
    "db:diagram:puml": "corepack pnpm --filter @corelia/api exec tsx ../../scripts/generate-db-puml.ts",
    "db:diagram:render": "bash scripts/render-puml.sh",
    "db:diagram:check": "bash scripts/check-puml-up-to-date.sh",
    "search:reindex": "corepack pnpm --filter @corelia/api exec tsx ../../scripts/reindex-search.ts",
    "push:generate-keys": "corepack pnpm --filter @corelia/workers exec web-push generate-vapid-keys",
    "backfill:project-general-channels": "corepack pnpm --filter @corelia/api exec tsx ../../scripts/backfill-project-general-channels.ts",
    "bootstrap:admin": "corepack pnpm --filter @corelia/api exec tsx ../../scripts/bootstrap-admin.ts",
    "prisma:generate": "pnpm --filter @corelia/api prisma:generate",
    "prisma:seed": "pnpm --filter @corelia/api prisma:seed",
    "prisma:migrate:dev": "pnpm --filter @corelia/api prisma:migrate:dev",
    "prisma:migrate:deploy": "pnpm --filter @corelia/api prisma:migrate:deploy",
    "prisma:migrate:status": "pnpm --filter @corelia/api prisma:migrate:status"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "turbo": "^2.3.3"
  },
  "pnpm": {
    "overrides": {
      "@grpc/grpc-js": "1.14.4",
      "@excalidraw/mermaid-to-excalidraw": "1.1.3",
      "@opentelemetry/core": "2.8.0",
      "brace-expansion@<2.0.0": "1.1.13",
      "brace-expansion@>=2.0.0 <3.0.0": "2.0.3",
      "brace-expansion@>=5.0.0 <5.0.6": "5.0.6",
      "defu": "6.1.7",
      "dompurify": "3.4.11",
      "effect": "3.21.4",
      "fast-uri": "3.1.2",
      "fast-jwt": "6.2.4",
      "fast-xml-builder": "1.1.7",
      "fast-xml-parser": "5.9.3",
      "flatted": "3.4.2",
      "js-yaml": "4.2.0",
      "lodash": "4.18.1",
      "lodash-es": "4.18.1",
      "nanoid": "5.1.6",
      "mermaid": "11.15.0",
      "picomatch@<3.0.0": "2.3.2",
      "picomatch@>=4.0.0 <4.0.4": "4.0.4",
      "postcss": "8.5.15",
      "protobufjs": "8.6.4",
      "socket.io-parser": "4.2.6",
      "tar": "7.5.16",
      "tmp": "0.2.7",
      "uuid@<11.1.1": "11.1.1",
      "ws": "8.21.0"
    },
    "patchedDependencies": {
      "@sawport/peers-caller@0.0.1": "patches/@sawport__peers-caller@0.0.1.patch"
    }
  }
}
